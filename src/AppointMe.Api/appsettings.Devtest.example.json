{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Frontend": {
    "BaseUrl": "https://app.your-domain.example"
  },
  "Authentication": {
    "Provider": "EntraExternalId",
    "RequireHttpsMetadata": true,
    "EntraExternalId": {
      "Authority": "https://<your-tenant>.ciamlogin.com/<your-tenant-id>/v2.0",
      "ClientId": "<your-api-app-client-id>",
      "ApiAudience": "api://<your-api-app-client-id>"
    }
  },
  "EntraIdentity": {
    "TenantId": "<your-tenant-id>",
    "ClientId": "<your-api-app-client-id>"
  },
  "Wolverine": {
    "Transport": "AzureServiceBus"
  },
  "Demo": {
    "Enabled": true,
    "User": {
      "Email": "demo@your-domain.example",
      "Password": "<demo-user-password>",
      "Name": "Demo User"
    }
  }
}
